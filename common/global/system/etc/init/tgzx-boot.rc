#
# tgzx-boot: runs once at post-fs-data time to apply the permissive/
# enforcing SELinux decision + any other late-boot tweaks.
#
# Lives at /system/etc/init/tgzx-boot.rc → ends up auto-loaded by init.
#

service tgzx-boot /system/bin/tgzx-boot.sh
    class late_start
    user root
    group root
    oneshot
    seclabel u:r:su:s0

on property:sys.boot_completed=1
    start tgzx-boot
